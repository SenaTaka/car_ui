{
  "sourceLanguage": "ja",
  "strings": {
    "CFBundleDisplayName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OBD2 Scanner"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OBD2スキャナー"
          }
        }
      }
    },
    "NSBluetoothAlwaysUsageDescription": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bluetooth is used to connect to your ELM327 OBD2 adapter and read vehicle data."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ELM327 OBD2 アダプタに接続して車両情報を読み取るために Bluetooth を使用します。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your location is used to record GPS speed, altitude, and distance traveled."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GPS の速度・高度・走行距離を記録するために位置情報を使用します。"
          }
        }
      }
    },
    "NSMotionUsageDescription": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The motion sensor is used to display and record G-force."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "G フォースの表示・記録のためにモーションセンサーを使用します。"
          }
        }
      }
    }
  },
  "version": "1.0"
}